# bb-auth deployment configuration — TEMPLATE.
#
# Copy this to `deploy/bb-auth.env` (gitignored), fill in the real values for your
# deployment, and stage it for the deploy script. The deploy script installs it to
# <install-dir>/bb-auth.env (0640, service-user readable) and generates the
# BB_AUTH_HMAC_KEY on first run if it is empty — so the secret only ever exists on
# the host. NEVER commit the filled-in file.

# Where bb-auth listens (the reverse proxy proxies to it). Loopback only.
BB_AUTH_LISTEN=127.0.0.1:4181

# Secret used to sign session cookies (HMAC-SHA256), >= 32 bytes.
# Leave EMPTY here: the deploy script generates one on first install and preserves
# it across redeploys. (To set it by hand: openssl rand -base64 48)
BB_AUTH_HMAC_KEY=

# Key id stamped into new cookies (bb2.<keyid>.<exp>.<email>.<sig>). Must match
# [A-Za-z0-9_-]+ (no '.'). Bump it when rotating BB_AUTH_HMAC_KEY so verify can
# still honour cookies signed under the previous key. See README "Key rotation".
BB_AUTH_HMAC_KEY_ID=default

# Optional: extra keys accepted for verification during rotation, as a comma-
# separated list of `id:key` (key = an `openssl rand -base64 48` string). Leave
# empty when there is only one key. Example for a k1->k2 rollover window:
#   BB_AUTH_HMAC_ACCEPTED_KEYS=k2:NEW_base64_key_here
BB_AUTH_HMAC_ACCEPTED_KEYS=

# Cognito user-pool issuer (JWKS URL is derived from this).
BB_AUTH_COGNITO_ISSUER=https://cognito-idp.<region>.amazonaws.com/<user-pool-id>

# Public app client id the login page uses (id_token.aud must equal this).
BB_AUTH_CLIENT_ID=<app-client-id>

# Optional extra accepted audiences (Cognito app client ids), comma-separated.
# BB_AUTH_CLIENT_ID is always accepted; this appends others — e.g. a separate
# social-login app client. A token is valid if its `aud` matches any of them.
# Read once at startup, so changes require `systemctl restart bb-auth` (not reload).
#BB_AUTH_AUDIENCES=<social-app-client-id>

# Optional: relax the `email_verified` requirement, but ONLY for federated
# (social) logins — never for native Cognito users. Cognito can't verify the
# email of a social sign-up (Google/Apple/...) so it stamps email_verified=false
# even though the IdP asserted the address; native self-signup stays strict
# (an unverified native email is attacker-controlled). Off (strict) by default.
#BB_AUTH_ALLOW_UNVERIFIED_SOCIAL=true

# Optional companion to the above: restrict the relaxation to specific IdPs,
# comma-separated, matched case-insensitively against the token's
# identities[].providerName (e.g. Google, SignInWithApple). Empty = any
# federated provider. Prefer listing only providers that verify the email.
#BB_AUTH_SOCIAL_PROVIDERS=Google,SignInWithApple

# Allowlist file: one email per line, '#' comments allowed. Re-checked on every
# /auth/validate; edit + `systemctl reload bb-auth` (SIGHUP) to apply live, or
# `systemctl restart bb-auth`.
BB_AUTH_ALLOWLIST_FILE=/opt/bb-auth/allowed_emails

# Session cookie.
BB_AUTH_COOKIE_NAME=bb_session
# Empty = host-only cookie (per-service login). Set to a parent domain
# (e.g. ".example.com") for cross-service SSO shared by every service behind the gate.
BB_AUTH_COOKIE_DOMAIN=
BB_AUTH_SESSION_TTL_SECS=2592000

# Base URL of the service this instance fronts (post-login redirect target / rd guard).
BB_AUTH_SEARCH_URL=https://app.example.com/
# Login page (401 / logout land here).
BB_AUTH_LOGIN_URL=https://login.example.com/

BB_AUTH_WORKERS=4
